<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ORIGIN — India's Coffee Discovery Page</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --espresso: #1a0f00;
    --dark-brown: #2d1a00;
    --mid-brown: #5c3a1e;
    --gold: #c9963a;
    --gold-light: #e8b96a;
    --cream: #f7f0e6;
    --parchment: #ede4d4;
    --text-dark: #1a0f00;
    --text-mid: #4a3520;
    --coming-soon-bg: #2d1a00;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
font-family: ‘DM Sans’, sans-serif;
background: var(–espresso);
color: var(–cream);
overflow-x: hidden;
}

/* ── HERO ── */
.hero {
min-height: 100vh;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
text-align: center;
padding: 60px 24px 80px;
position: relative;
background: radial-gradient(ellipse at 50% 30%, #3d2000 0%, #1a0f00 60%, #0d0700 100%);
overflow: hidden;
}

.hero::before {
content: ‘’;
position: absolute;
width: 600px; height: 600px;
border-radius: 50%;
background: radial-gradient(circle, rgba(201,150,58,0.12) 0%, transparent 70%);
top: 50%; left: 50%;
transform: translate(-50%,-50%);
pointer-events: none;
}

.hero-corner {
position: absolute;
width: 40px; height: 40px;
border-color: var(–gold);
border-style: solid;
opacity: 0.5;
}
.hero-corner.tl { top: 24px; left: 24px; border-width: 1px 0 0 1px; }
.hero-corner.tr { top: 24px; right: 24px; border-width: 1px 1px 0 0; }
.hero-corner.bl { bottom: 24px; left: 24px; border-width: 0 0 1px 1px; }
.hero-corner.br { bottom: 24px; right: 24px; border-width: 0 1px 1px 0; }

.hero-eyebrow {
font-family: ‘DM Sans’, sans-serif;
font-size: 10px;
font-weight: 500;
letter-spacing: 0.35em;
color: var(–gold);
text-transform: uppercase;
margin-bottom: 28px;
opacity: 0;
animation: fadeUp 0.8s 0.2s forwards;
}

.hero h1 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(52px, 10vw, 100px);
font-weight: 900;
line-height: 0.95;
color: var(–cream);
margin-bottom: 8px;
opacity: 0;
animation: fadeUp 0.8s 0.4s forwards;
}

.hero h1 em {
font-style: italic;
color: var(–gold);
}

.hero-tagline {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(16px, 3vw, 22px);
font-style: italic;
font-weight: 300;
color: rgba(247,240,230,0.65);
margin: 24px 0 48px;
opacity: 0;
animation: fadeUp 0.8s 0.6s forwards;
}

.hero-nav {
display: flex;
gap: 2px;
border: 1px solid rgba(201,150,58,0.3);
opacity: 0;
animation: fadeUp 0.8s 0.8s forwards;
}

.hero-nav a {
padding: 18px 28px;
text-decoration: none;
font-size: 11px;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–cream);
font-weight: 400;
transition: all 0.3s;
border-right: 1px solid rgba(201,150,58,0.3);
position: relative;
display: flex;
flex-direction: column;
align-items: center;
gap: 10px;
}

.hero-nav a:last-child { border-right: none; }

.hero-nav a .nav-icon { font-size: 22px; }

.hero-nav a:hover {
background: rgba(201,150,58,0.1);
color: var(–gold-light);
}

.hero-nav a.active-nav {
background: rgba(201,150,58,0.12);
}

.badge-coming {
font-size: 8px;
letter-spacing: 0.12em;
background: rgba(201,150,58,0.2);
color: var(–gold);
padding: 2px 6px;
border-radius: 20px;
border: 1px solid rgba(201,150,58,0.3);
white-space: nowrap;
margin-top: 4px;
}

.hero-brand {
margin-top: 52px;
font-family: ‘DM Sans’, sans-serif;
font-size: 11px;
letter-spacing: 0.5em;
text-transform: uppercase;
color: var(–gold);
opacity: 0;
animation: fadeUp 0.8s 1s forwards;
}

/* ── COMING SOON SECTION ── */
.coming-soon-strip {
background: var(–dark-brown);
border-top: 1px solid rgba(201,150,58,0.2);
border-bottom: 1px solid rgba(201,150,58,0.2);
padding: 64px 24px;
}

.section-label {
font-size: 10px;
letter-spacing: 0.35em;
text-transform: uppercase;
color: var(–gold);
text-align: center;
margin-bottom: 16px;
}

.section-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(28px, 5vw, 48px);
font-weight: 700;
text-align: center;
color: var(–cream);
margin-bottom: 12px;
}

.section-sub {
font-family: ‘Cormorant Garamond’, serif;
font-size: 18px;
font-style: italic;
color: rgba(247,240,230,0.55);
text-align: center;
max-width: 540px;
margin: 0 auto 48px;
}

.coming-cards {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
gap: 2px;
max-width: 900px;
margin: 0 auto;
border: 1px solid rgba(201,150,58,0.2);
}

.coming-card {
background: rgba(26,15,0,0.6);
padding: 32px 28px;
position: relative;
transition: background 0.3s;
}

.coming-card:hover {
background: rgba(201,150,58,0.06);
}

.coming-card-icon {
font-size: 28px;
margin-bottom: 16px;
}

.coming-card h3 {
font-family: ‘Playfair Display’, serif;
font-size: 20px;
font-weight: 700;
color: var(–cream);
margin-bottom: 10px;
}

.coming-card p {
font-size: 13px;
line-height: 1.7;
color: rgba(247,240,230,0.55);
margin-bottom: 20px;
}

.tag-soon {
display: inline-block;
font-size: 9px;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–gold);
border: 1px solid rgba(201,150,58,0.4);
padding: 4px 10px;
border-radius: 2px;
}

/* ── DIVIDER ── */
.divider {
display: flex;
align-items: center;
gap: 16px;
max-width: 600px;
margin: 0 auto;
padding: 0 24px;
}
.divider-line { flex: 1; height: 1px; background: rgba(201,150,58,0.2); }
.divider-dot { width: 4px; height: 4px; border-radius: 50%; background: var(–gold); opacity: 0.5; }

/* ── COFFEE GUIDE SECTION ── */
.guide-section {
background: var(–cream);
color: var(–text-dark);
padding: 80px 24px;
}

.guide-section .section-label { color: var(–mid-brown); }
.guide-section .section-title { color: var(–espresso); }
.guide-section .section-sub { color: var(–mid-brown); }

.guide-intro-box {
background: var(–espresso);
border-left: 3px solid var(–gold);
padding: 28px 32px;
max-width: 700px;
margin: 0 auto 56px;
}

.guide-intro-box p {
font-family: ‘Cormorant Garamond’, serif;
font-size: 18px;
font-style: italic;
color: var(–cream);
line-height: 1.7;
}

/* Guide Steps */
.guide-steps {
max-width: 820px;
margin: 0 auto;
}

.guide-step {
margin-bottom: 48px;
border-bottom: 1px solid rgba(92,58,30,0.12);
padding-bottom: 48px;
}
.guide-step:last-child { border-bottom: none; }

.step-header {
display: flex;
align-items: flex-start;
gap: 20px;
margin-bottom: 24px;
}

.step-num {
font-family: ‘Playfair Display’, serif;
font-size: 48px;
font-weight: 900;
color: var(–gold);
opacity: 0.35;
line-height: 1;
flex-shrink: 0;
width: 52px;
}

.step-title-block h2 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(22px, 4vw, 32px);
font-weight: 700;
color: var(–espresso);
margin-bottom: 4px;
}

.step-title-block .step-sub {
font-family: ‘Cormorant Garamond’, serif;
font-size: 16px;
font-style: italic;
color: var(–mid-brown);
}

/* Region cards */
.region-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
gap: 16px;
}

.region-card {
background: var(–parchment);
border: 1px solid rgba(92,58,30,0.15);
padding: 24px;
position: relative;
transition: transform 0.2s, box-shadow 0.2s;
}

.region-card:hover {
transform: translateY(-3px);
box-shadow: 0 8px 32px rgba(92,58,30,0.15);
}

.region-name {
font-family: ‘Playfair Display’, serif;
font-size: 18px;
font-weight: 700;
color: var(–espresso);
margin-bottom: 4px;
}

.region-loc {
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 14px;
}

.region-stats {
display: flex;
flex-direction: column;
gap: 6px;
margin-bottom: 14px;
}

.stat-row {
display: flex;
justify-content: space-between;
font-size: 11px;
color: var(–mid-brown);
letter-spacing: 0.08em;
text-transform: uppercase;
}
.stat-row span:last-child {
font-weight: 500;
color: var(–espresso);
}

.region-taste {
font-family: ‘Cormorant Garamond’, serif;
font-size: 14px;
font-style: italic;
color: var(–mid-brown);
border-top: 1px solid rgba(92,58,30,0.15);
padding-top: 12px;
margin-top: 4px;
}

.region-tags {
display: flex;
flex-wrap: wrap;
gap: 6px;
margin-top: 12px;
}

.rtag {
font-size: 9px;
letter-spacing: 0.15em;
text-transform: uppercase;
border: 1px solid rgba(92,58,30,0.25);
color: var(–mid-brown);
padding: 3px 8px;
border-radius: 2px;
}

/* Roast section */
.roast-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 0;
border: 1px solid rgba(92,58,30,0.15);
}

.roast-card {
padding: 28px 24px;
border-right: 1px solid rgba(92,58,30,0.15);
background: var(–parchment);
transition: background 0.2s;
}
.roast-card:last-child { border-right: none; }
.roast-card:hover { background: #e5dace; }

.roast-level {
font-family: ‘Playfair Display’, serif;
font-size: 20px;
font-weight: 700;
color: var(–espresso);
margin-bottom: 4px;
}

.roast-desc {
font-size: 12px;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 14px;
font-weight: 500;
}

.roast-notes {
font-family: ‘Cormorant Garamond’, serif;
font-size: 15px;
font-style: italic;
color: var(–mid-brown);
line-height: 1.6;
margin-bottom: 12px;
}

.roast-best {
font-size: 11px;
color: rgba(92,58,30,0.7);
border-top: 1px solid rgba(92,58,30,0.12);
padding-top: 10px;
}

.myth-box {
background: var(–espresso);
border: 1px solid rgba(201,150,58,0.25);
padding: 20px 24px;
margin-top: 16px;
}

.myth-box p {
font-size: 13px;
line-height: 1.7;
color: rgba(247,240,230,0.75);
}

.myth-box strong {
color: var(–gold);
}

/* Process section */
.process-list {
display: flex;
flex-direction: column;
gap: 16px;
}

.process-item {
background: var(–parchment);
border: 1px solid rgba(92,58,30,0.15);
padding: 24px 28px;
display: grid;
grid-template-columns: auto 1fr;
gap: 20px;
align-items: start;
transition: background 0.2s;
}
.process-item:hover { background: #e5dace; }

.process-icon { font-size: 28px; margin-top: 2px; }

.process-name {
font-family: ‘Playfair Display’, serif;
font-size: 18px;
font-weight: 700;
color: var(–espresso);
margin-bottom: 4px;
}

.process-subtitle {
font-size: 11px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 10px;
}

.process-text {
font-size: 13px;
line-height: 1.7;
color: var(–text-mid);
}

.process-vibe {
display: inline-block;
margin-top: 10px;
font-family: ‘Cormorant Garamond’, serif;
font-size: 14px;
font-style: italic;
font-weight: 600;
color: var(–mid-brown);
}

/* Brew methods */
.brew-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
gap: 16px;
}

.brew-card {
background: var(–parchment);
border: 1px solid rgba(92,58,30,0.15);
padding: 22px;
transition: transform 0.2s, box-shadow 0.2s;
}
.brew-card:hover {
transform: translateY(-3px);
box-shadow: 0 8px 24px rgba(92,58,30,0.12);
}

.brew-header {
display: flex;
justify-content: space-between;
align-items: flex-start;
margin-bottom: 12px;
}

.brew-name {
font-family: ‘Playfair Display’, serif;
font-size: 18px;
font-weight: 700;
color: var(–espresso);
}

.brew-difficulty {
font-size: 9px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–gold);
background: rgba(201,150,58,0.1);
border: 1px solid rgba(201,150,58,0.25);
padding: 3px 7px;
border-radius: 2px;
white-space: nowrap;
flex-shrink: 0;
}

.brew-stats {
display: flex;
gap: 16px;
margin-bottom: 12px;
flex-wrap: wrap;
}

.brew-stat {
font-size: 11px;
color: var(–mid-brown);
}
.brew-stat strong {
display: block;
font-size: 12px;
color: var(–espresso);
font-weight: 500;
}

.brew-text {
font-size: 12px;
line-height: 1.7;
color: var(–text-mid);
margin-bottom: 12px;
}

.brew-perfect {
font-size: 11px;
color: var(–mid-brown);
border-top: 1px solid rgba(92,58,30,0.12);
padding-top: 10px;
font-style: italic;
}

/* Buying tips */
.tips-list {
display: flex;
flex-direction: column;
gap: 0;
border: 1px solid rgba(92,58,30,0.15);
}

.tip-item {
display: grid;
grid-template-columns: 52px 1fr;
gap: 0;
border-bottom: 1px solid rgba(92,58,30,0.12);
transition: background 0.2s;
}
.tip-item:last-child { border-bottom: none; }
.tip-item:hover { background: #e5dace; }

.tip-num {
background: var(–espresso);
color: var(–gold);
font-family: ‘Playfair Display’, serif;
font-size: 22px;
font-weight: 700;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
}

.tip-body {
background: var(–parchment);
padding: 22px 24px;
}

.tip-body h3 {
font-family: ‘Playfair Display’, serif;
font-size: 17px;
font-weight: 700;
color: var(–espresso);
margin-bottom: 8px;
}

.tip-body p {
font-size: 13px;
line-height: 1.7;
color: var(–text-mid);
}

/* Cheatsheet */
.cheatsheet {
background: var(–espresso);
border: 1px solid rgba(201,150,58,0.2);
padding: 36px 32px;
margin-top: 40px;
}

.cheat-title {
font-family: ‘Playfair Display’, serif;
font-size: 28px;
font-weight: 700;
color: var(–cream);
margin-bottom: 24px;
}
.cheat-title em {
color: var(–gold);
font-style: italic;
}

.cheat-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
gap: 0;
border-top: 1px solid rgba(201,150,58,0.15);
}

.cheat-item {
padding: 16px 0 16px 20px;
border-bottom: 1px solid rgba(201,150,58,0.1);
border-left: 2px solid rgba(201,150,58,0.25);
margin-bottom: 12px;
}

.cheat-q {
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 6px;
font-weight: 500;
}

.cheat-a {
font-size: 13px;
line-height: 1.6;
color: rgba(247,240,230,0.8);
}

/* ── VISION SECTION ── */
.vision-section {
background: var(–dark-brown);
padding: 80px 24px;
text-align: center;
}

.vision-inner {
max-width: 680px;
margin: 0 auto;
}

.vision-quote {
font-family: ‘Playfair Display’, serif;
font-size: clamp(22px, 4vw, 36px);
font-weight: 700;
color: var(–cream);
line-height: 1.3;
margin-bottom: 20px;
}

.vision-quote em { color: var(–gold); font-style: italic; }

.vision-body {
font-family: ‘Cormorant Garamond’, serif;
font-size: 18px;
font-style: italic;
color: rgba(247,240,230,0.6);
line-height: 1.7;
margin-bottom: 48px;
}

.pillars {
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 2px;
margin-bottom: 48px;
text-align: left;
}

.pillar {
background: rgba(255,255,255,0.04);
padding: 24px;
border: 1px solid rgba(201,150,58,0.15);
}

.pillar h4 {
font-family: ‘Playfair Display’, serif;
font-size: 16px;
font-weight: 700;
color: var(–gold);
margin-bottom: 8px;
}

.pillar p {
font-size: 13px;
line-height: 1.6;
color: rgba(247,240,230,0.55);
}

/* ── CONTACT ── */
.contact-section {
background: var(–espresso);
border-top: 1px solid rgba(201,150,58,0.2);
padding: 72px 24px;
text-align: center;
}

.contact-name {
font-family: ‘Playfair Display’, serif;
font-size: 28px;
font-weight: 700;
color: var(–cream);
margin-bottom: 6px;
}

.contact-role {
font-family: ‘Cormorant Garamond’, serif;
font-size: 16px;
font-style: italic;
color: rgba(247,240,230,0.5);
margin-bottom: 32px;
}

.contact-links {
display: flex;
flex-wrap: wrap;
justify-content: center;
gap: 12px;
margin-bottom: 48px;
}

.contact-link {
display: flex;
align-items: center;
gap: 8px;
padding: 12px 20px;
border: 1px solid rgba(201,150,58,0.3);
color: var(–cream);
text-decoration: none;
font-size: 13px;
font-weight: 400;
transition: all 0.3s;
background: rgba(255,255,255,0.03);
}

.contact-link:hover {
background: rgba(201,150,58,0.1);
border-color: rgba(201,150,58,0.6);
color: var(–gold-light);
}

.contact-link .link-icon { font-size: 16px; }

.footer-brand {
font-family: ‘DM Sans’, sans-serif;
font-size: 11px;
letter-spacing: 0.5em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 8px;
}

.footer-tagline {
font-family: ‘Cormorant Garamond’, serif;
font-size: 14px;
font-style: italic;
color: rgba(247,240,230,0.3);
}

/* ── ANIMATIONS ── */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(20px); }
to { opacity: 1; transform: translateY(0); }
}

/* ── STICKY TOC ── */
.toc {
position: sticky;
top: 0;
z-index: 100;
background: rgba(26,15,0,0.97);
backdrop-filter: blur(12px);
border-bottom: 1px solid rgba(201,150,58,0.2);
padding: 12px 24px;
display: flex;
align-items: center;
gap: 4px;
overflow-x: auto;
scrollbar-width: none;
}
.toc::-webkit-scrollbar { display: none; }

.toc-brand {
font-family: ‘DM Sans’, sans-serif;
font-size: 11px;
letter-spacing: 0.3em;
color: var(–gold);
text-transform: uppercase;
flex-shrink: 0;
margin-right: 12px;
}

.toc a {
text-decoration: none;
font-size: 10px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: rgba(247,240,230,0.55);
white-space: nowrap;
padding: 6px 12px;
border-radius: 2px;
transition: all 0.2s;
flex-shrink: 0;
}

.toc a:hover {
color: var(–gold-light);
background: rgba(201,150,58,0.08);
}

/* ── RESPONSIVE ── */
@media (max-width: 600px) {
.hero-nav { flex-direction: column; gap: 0; }
.hero-nav a { border-right: none; border-bottom: 1px solid rgba(201,150,58,0.3); flex-direction: row; justify-content: center; }
.hero-nav a:last-child { border-bottom: none; }
.roast-grid { grid-template-columns: 1fr; }
.roast-card { border-right: none; border-bottom: 1px solid rgba(92,58,30,0.15); }
.roast-card:last-child { border-bottom: none; }
.pillars { grid-template-columns: 1fr; }
.guide-intro-box { padding: 20px; }
.cheatsheet { padding: 24px 20px; }
}
</style>

</head>
<body>

<!-- HERO -->

<section class="hero" id="top">
  <div class="hero-corner tl"></div>
  <div class="hero-corner tr"></div>
  <div class="hero-corner bl"></div>
  <div class="hero-corner br"></div>

  <div class="hero-eyebrow">Origin &nbsp;·&nbsp; India's Coffee Discovery Page</div>
  <h1>Your coffee.<br><em>Your estate.</em></h1>
  <p class="hero-tagline">No jargon. No middlemen.<br>Just the honest story of Indian coffee.</p>

  <div class="hero-nav">
    <a href="#guide">
      <span class="nav-icon">🌿</span>
      Read the Guide
    </a>
    <a href="#beans-subscriptions">
      <span class="nav-icon">📦</span>
      Bean Subscriptions
